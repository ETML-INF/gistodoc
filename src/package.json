{
  "name": "gistodoc",
  "version": "1.0.0",
  "description": "Exporter les github issues en format markdown ou Word",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "server": "node server.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "build": {
    "appId": "ch.github.gistodoc",
    "productName": "gistodoc",
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/logo.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "dependencies": {
    "docx": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^25.0.0"
  }
}
